# Copy this to .env and fill in your values.
# Never commit .env to git.

# Get your key at: https://steamcommunity.com/dev/apikey
# Requires Steam Guard enabled on your account.
STEAM_API_KEY=your_steam_api_key_here

# Neon Postgres connection string (sign up free at neon.tech)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/steam_sale_lift?sslmode=require

# Optional: override scraper defaults
# REQUESTS_PER_5MIN=180
# STEAMDB_DELAY_SECS=3
# MAX_GAMES=3000
